MINIMAX_API_KEY=your-minimax-api-key
MINIMAX_BASE_URL=https://api.minimax.io/anthropic
MINIMAX_MODEL=MiniMax-M2.1
MAX_TOKENS=4096
# /analyze (page summary) uses MiniMax.
# /agent (follow-up advisor chat) prefers AWS Bedrock.
# Comma-separated list, for example:
# ALLOWED_ORIGINS=https://your-app.example.com,chrome-extension://<your-extension-id>
ALLOWED_ORIGINS=*
ALLOW_CREDENTIALS=false
AWS_REGION=ap-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
# Optional explicit Bedrock creds; if omitted, default AWS credential chain is used.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_AGENT_ID=
BEDROCK_AGENT_ALIAS_ID=
